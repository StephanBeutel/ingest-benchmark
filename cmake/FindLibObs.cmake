# FindLibObs.cmake — Locates libobs and obs-frontend-api for out-of-tree builds on macOS.
#
# Usage:
#   cmake .. -DOBS_SOURCE_DIR=/tmp/obs-headers \
#             -DOBS_APP=/Applications/OBS.app
#
# Exports:
#   OBS::libobs             — imported target
#   OBS::obs-frontend-api   — imported target

cmake_minimum_required(VERSION 3.22)

# ── Paths ────────────────────────────────────────────────────────────────────
if(NOT DEFINED OBS_APP)
    set(OBS_APP "/Applications/OBS.app" CACHE PATH "Path to OBS.app")
endif()

if(NOT DEFINED OBS_SOURCE_DIR)
    set(OBS_SOURCE_DIR "" CACHE PATH "Path to obs-studio source (for headers)")
endif()

set(OBS_FRAMEWORKS "${OBS_APP}/Contents/Frameworks")

# ── Validate ─────────────────────────────────────────────────────────────────
if(NOT EXISTS "${OBS_FRAMEWORKS}/libobs.framework")
    message(FATAL_ERROR "libobs.framework not found in ${OBS_FRAMEWORKS}.\n"
        "Set OBS_APP to the correct OBS.app location.")
endif()

if(OBS_SOURCE_DIR STREQUAL "" OR NOT EXISTS "${OBS_SOURCE_DIR}/libobs/obs-module.h")
    message(FATAL_ERROR
        "OBS source headers not found.\n"
        "Set OBS_SOURCE_DIR to a checkout of obs-studio source.\n"
        "  cmake .. -DOBS_SOURCE_DIR=/tmp/obs-headers")
endif()

# ── libobs imported target ───────────────────────────────────────────────────
if(NOT TARGET OBS::libobs)
    add_library(OBS::libobs SHARED IMPORTED GLOBAL)
    set_target_properties(OBS::libobs PROPERTIES
        IMPORTED_LOCATION "${OBS_FRAMEWORKS}/libobs.framework/libobs"
        FRAMEWORK TRUE
    )
    # Headers: libobs/ directory in the source tree
    target_include_directories(OBS::libobs INTERFACE
        "${OBS_SOURCE_DIR}"          # for <obs.h>, <obs-module.h> etc.
        "${OBS_SOURCE_DIR}/libobs"
        # obsconfig.h is normally generated by OBS's cmake configure.
        # For out-of-tree plugin builds we ship a pre-filled version.
        "${CMAKE_CURRENT_LIST_DIR}"
    )
    # simde (SIMD Everywhere) is required by OBS graphics headers.
    # Find it in the standard Homebrew location on macOS or via pkg-config.
    find_path(_simde_include_dir simde/simde-common.h
        PATHS
            /opt/homebrew/include
            /usr/local/include
        DOC "Path to simde headers"
    )
    if(_simde_include_dir)
        target_include_directories(OBS::libobs INTERFACE "${_simde_include_dir}")
    else()
        message(WARNING "simde headers not found — install via: brew install simde")
    endif()
endif()

# ── obs-frontend-api imported target ─────────────────────────────────────────
# OBS 32.x ships both obs-frontend-api.dylib and libobs-frontend-api.1.dylib
if(NOT TARGET OBS::obs-frontend-api)
    # Prefer the versioned one
    if(EXISTS "${OBS_FRAMEWORKS}/libobs-frontend-api.1.dylib")
        set(_fe_lib "${OBS_FRAMEWORKS}/libobs-frontend-api.1.dylib")
    elseif(EXISTS "${OBS_FRAMEWORKS}/obs-frontend-api.dylib")
        set(_fe_lib "${OBS_FRAMEWORKS}/obs-frontend-api.dylib")
    else()
        message(FATAL_ERROR "obs-frontend-api dylib not found in ${OBS_FRAMEWORKS}")
    endif()

    add_library(OBS::obs-frontend-api SHARED IMPORTED GLOBAL)
    set_target_properties(OBS::obs-frontend-api PROPERTIES
        IMPORTED_LOCATION "${_fe_lib}"
    )
    # Headers: frontend/api/ in OBS 32.x
    target_include_directories(OBS::obs-frontend-api INTERFACE
        "${OBS_SOURCE_DIR}/frontend/api"
    )
    target_link_libraries(OBS::obs-frontend-api INTERFACE OBS::libobs)
endif()

# ── OBS-bundled Qt imported targets ──────────────────────────────────────────
# We link against OBS's own Qt frameworks so the embedded LC_LOAD_DYLIB version
# matches what OBS ships (6.8.3), not the Homebrew compile-time version (6.11).
# dyld rejects a plugin that declares it needs 6.11 when only 6.8.3 is present.
#
# We use Homebrew Qt headers (for MOC and compilation) but link the actual
# .framework binaries from OBS.app so the version tag is correct.
#
# QtConcurrent is not shipped by OBS.app — it is not used in this plugin and
# must not appear in target_link_libraries.

# Locate Homebrew Qt headers for MOC / compilation
find_package(Qt6 QUIET COMPONENTS Core Gui Widgets)
if(Qt6_FOUND)
    set(_qt_include_dirs
        "${Qt6Core_INCLUDE_DIRS}"
        "${Qt6Gui_INCLUDE_DIRS}"
        "${Qt6Widgets_INCLUDE_DIRS}"
    )
else()
    # Fallback: derive from qmake
    find_program(_qmake qmake)
    if(_qmake)
        execute_process(COMMAND "${_qmake}" -query QT_INSTALL_HEADERS
            OUTPUT_VARIABLE _qt_hdr OUTPUT_STRIP_TRAILING_WHITESPACE)
        set(_qt_include_dirs "${_qt_hdr}"
            "${_qt_hdr}/QtCore" "${_qt_hdr}/QtGui"
            "${_qt_hdr}/QtWidgets" "${_qt_hdr}/QtNetwork")
    endif()
endif()

foreach(_qt_comp Core Gui Widgets)
    set(_fw "${OBS_FRAMEWORKS}/Qt${_qt_comp}.framework")
    if(EXISTS "${_fw}")
        if(NOT TARGET OBS::Qt${_qt_comp})
            add_library(OBS::Qt${_qt_comp} SHARED IMPORTED GLOBAL)
            set_target_properties(OBS::Qt${_qt_comp} PROPERTIES
                IMPORTED_LOCATION "${_fw}/Versions/A/Qt${_qt_comp}"
                FRAMEWORK TRUE
            )
            # Headers from Homebrew Qt so MOC and compilation work
            target_include_directories(OBS::Qt${_qt_comp} INTERFACE
                ${_qt_include_dirs}
            )
        endif()
    else()
        message(WARNING "Qt${_qt_comp}.framework not found in OBS.app — skipping")
    endif()
endforeach()

message(STATUS "FindLibObs: libobs     = ${OBS_FRAMEWORKS}/libobs.framework/libobs")
message(STATUS "FindLibObs: frontend   = ${_fe_lib}")
message(STATUS "FindLibObs: headers    = ${OBS_SOURCE_DIR}")
message(STATUS "FindLibObs: Qt         = OBS-bundled 6.8.3 (headers from Homebrew)")
